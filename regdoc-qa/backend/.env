# --- Anthropic Claude (generation only; embeddings run locally and need no key) ---
# Get a key at https://console.anthropic.com  → required to answer questions.
ANTHROPIC_API_KEY=
# Generation model. Sonnet 4.6 = balanced default. Use claude-haiku-4-5 for lowest cost.
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=1024

# --- Vector store (local, persistent) ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=regdocs

# --- Retrieval / chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# --- Uploads ---
MAX_UPLOAD_MB=15

# --- CORS: comma-separated frontend origins ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
